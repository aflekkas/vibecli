{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun run typecheck)",
      "Bash(bun install)",
      "Bash(bun add:*)",
      "Bash(bun update:*)",
      "Bash(bun run dev)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git stash list)",
      "Bash(git ls-files:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh repo view:*)",
      "Bash(npm view:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)"
    ],
    "ask": [
      "Bash(bun run ship)",
      "Bash(bun run ship:minor)",
      "Bash(bun run ship:major)",
      "Bash(npm publish:*)",
      "Bash(npm version:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)"
    ]
  }
}
